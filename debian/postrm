#!/bin/sh
# postrm script for wallpaper-manager
#
# see: dh_installdeb(1)

set -e

# summary of how this script can be called:
#        * <postrm> `remove'
#        * <postrm> `purge'
#        * <old-postrm> `upgrade' <new-version>
#        * <new-postrm> `failed-upgrade' <old-version>
#        * <new-postrm> `abort-install'
#        * <new-postrm> `abort-install' <old-version>
#        * <new-postrm> `abort-upgrade' <old-version>
#        * <disappearer's-postrm> `disappear' <overwriter>
#          <overwriter-version>
# for details, see http://www.debian.org/doc/debian-policy/ or
# the debian-policy package

users=$( who | awk '{print $1}' | sed '/^root$/d' | uniq )
homedir="/home/$users"

case "$1" in
    purge)
	if [ -f /usr/bin/wallpaper-manager ]; then 
	rm /usr/bin/wallpaper-manager
	fi
	if [ -f /usr/bin/w-m ]; then 
	rm /usr/bin/w-m
	fi
	if [ -d /usr/share/doc/wallpaper_manager ]; then 
	rm -rf /usr/share/doc/wallpaper_manager
	fi
	if [ -f /usr/share/applications/wallpaper_manager.desktop ]; then 
	rm /usr/share/applications/wallpaper_manager.desktop
	fi
	if [ -f /usr/share/pixmaps/wall-manager-icon.png ]; then 
	rm /usr/share/pixmaps/wall-manager-icon.png
	fi
	if [ -d /usr/bin/.wallpaper_manager ]; then 
	rm -rf /usr/bin/.wallpaper_manager
	fi
	if [ -d /usr/bin/wallpaper_manager ]; then 
	rm -rf /usr/bin/wallpaper_manager
	fi
	if [ -d $homedir/.wallpaper_manager ]; then 
	rm -rf $homedir/.wallpaper_manager
	fi
	if [ -f $homedir/.gnome2/nautilus-scripts/wallpaper-manager ]; then
	rm $homedir/.gnome2/nautilus-scripts/wallpaper-manager
	fi
	if [ -f $homedir/.config/autostart/wm-app-indicador.desktop ]; then 
	rm $homedir/.config/autostart/wm-app-indicador.desktop
	fi
	if [ -f $homedir/.local/share/applications/wallpaper_manager.desktop ]; then 
	rm $homedir/.local/share/applications/wallpaper_manager.desktop
	fi
	if [ -f /etc/xdg/autostart/.wall-manager-start.desktop ]; then 
	rm /etc/xdg/autostart/.wall-manager-start.desktop
	fi
    ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
	if [ -f /usr/bin/wallpaper-manager ]; then 
	rm /usr/bin/wallpaper-manager
	fi
	if [ -f /usr/bin/w-m ]; then 
	rm /usr/bin/w-m
	fi
	if [ -d /usr/bin/.wallpaper_manager ]; then 
	rm -rf /usr/bin/.wallpaper_manager
	fi
	if [ -d /usr/share/doc/wallpaper_manager ]; then 
	rm -rf /usr/share/doc/wallpaper_manager
	fi
	if [ -f /usr/share/applications/wallpaper_manager.desktop ]; then 
	rm /usr/share/applications/wallpaper_manager.desktop
	fi
	if [ -f /usr/share/pixmaps/wall-manager-icon.png ]; then 
	rm /usr/share/pixmaps/wall-manager-icon.png
	fi
	if [ -d /usr/bin/wallpaper_manager ]; then 
	rm -rf /usr/bin/wallpaper_manager
	fi
	if [ -f $homedir/.gnome2/nautilus-scripts/wallpaper-manager ]; then
	rm $homedir/.gnome2/nautilus-scripts/wallpaper-manager
	fi
	if [ -f $homedir/.config/autostart/wm-app-indicador.desktop ]; then 
	rm $homedir/.config/autostart/wm-app-indicador.desktop
	fi
	if [ -f $homedir/.local/share/applications/wallpaper_manager.desktop ]; then 
	rm $homedir/.local/share/applications/wallpaper_manager.desktop
	fi
	if [ -f /etc/xdg/autostart/.wall-manager-start.desktop ]; then 
	rm /etc/xdg/autostart/.wall-manager-start.desktop
	fi
    ;;
    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

# dh_installdeb will replace this with shell code automatically
# generated by other debhelper scripts.

#DEBHELPER#

exit 0
